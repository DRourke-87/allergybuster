<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup / device-transfer configuration for Android 12+ (API >= 31).

  Both cloud-backup and device-transfer include all app data. None of it is
  sensitive: approximate location, pollen history, feedback.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
